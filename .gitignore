# GopherNotebook .gitignore

# ─── OS & IDE Files ───
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ─── Data & Persistence ───
# Ignore all uploaded PDFs, parsed DB arrays, Docker volumes, and local JSON config overrides
data/
backend/data/
docker_volumes/

# ─── Local AI Models ───
# Exclude GGUF multi-gigabyte models from git to prevent repository bloat
models/*.gguf
models/*.bin

# ─── Backend (Go) ───
# Ignore compiled binaries and runtime logs
backend/bin/
backend/server
backend/server.log
*.exe
*.test
*.prof
*.orig
*.rej

# ─── Frontend (Next.js) ───
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.pnp
frontend/.pnp.js
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.vercel
frontend/frontend.log

# ─── AI Agent Files ───
# Instruction files created by coding agents - not part of the project source
frontend/AGENTS.md
frontend/CLAUDE.md
AGENTS.md
CLAUDE.md

# ─── Miscellaneous ───
*.log
*.patch
*.py~
.env
